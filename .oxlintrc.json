{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import"],
  "rules": {
    "no-unused-vars": "warn",
    "react-in-jsx-scope": "off"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".tanstack",
    "src/routeTree.gen.ts",
    "storybook-static"
  ]
}
